# ReignX Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# Database Configuration
DATABASE_PASSWORD=your_secure_database_password_here

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_secure_jwt_secret_here

# SSH Password (optional, prefer using SSH keys)
SSH_PASSWORD=

# NATS Configuration (if using authentication)
NATS_USERNAME=
NATS_PASSWORD=

# Etcd Configuration (if using authentication)
ETCD_USERNAME=
ETCD_PASSWORD=

# Encryption Key for SSH password storage (generate with: openssl rand -base64 32)
REIGNX_ENCRYPTION_KEY=your_secure_encryption_key_here

# Optional: External Services
# JAEGER_URL=http://localhost:14268/api/traces
# PROMETHEUS_URL=http://localhost:9090
