# Kickstart configuration for {{ .Hostname }}
# Generated by ReignX PXE Server

# System authorization information
auth --enableshadow --passalgo=sha512

# Use network installation
url --url="http://{{ .ServerIP }}:{{ .HTTPPort }}/images/centos/7"

# Use text mode install
text

# Run the Setup Agent on first boot
firstboot --enable

# Keyboard layouts
keyboard --vckeymap=us --xlayouts='us'

# System language
lang en_US.UTF-8

# Network information
network --bootproto=dhcp --device=eth0 --onboot=on --ipv6=auto --activate
network --hostname={{ .Hostname }}

# Root password (encrypted)
rootpw --iscrypted {{ .RootPassword }}

# System services
services --enabled="chronyd"

# System timezone
timezone America/New_York --isUtc

# Bootloader configuration
bootloader --location=mbr --boot-drive=sda

# Partition clearing information
clearpart --none --initlabel

# Disk partitioning information
{{range .Partitions}}
part {{ .MountPoint }} --fstype={{ .FSType }} --size={{ .Size }}
{{end}}

# Packages
%packages
@^minimal
@core
chrony
{{ range .Packages }}
{{ . }}
{{ end }}
%end

# Post-installation script
%post --log=/root/ks-post.log

# Install SSH keys
mkdir -p /root/.ssh
chmod 700 /root/.ssh

{{range .SSHKeys}}
echo "{{ . }}" >> /root/.ssh/authorized_keys
{{end}}

chmod 600 /root/.ssh/authorized_keys

# Download and install ReignX agent
curl -o /tmp/reignx-agent http://{{ .ServerIP }}:{{ .HTTPPort }}/agents/linux-amd64
chmod +x /tmp/reignx-agent
/tmp/reignx-agent install --server={{ .ServerIP }}:9000

# Signal installation completion
curl -X POST "http://{{ .ServerIP }}:{{ .HTTPPort }}/complete/?server_id={{ .Hostname }}"

# Reboot after installation
reboot

%end
