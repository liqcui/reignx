# Example secrets configuration for ReignX
# Copy this file to .secrets and set your actual passwords
# NEVER commit .secrets to git!

# Database Configuration
export DATABASE_PASSWORD="your_secure_database_password_here"

# JWT Configuration
export JWT_SECRET="your_secure_jwt_secret_here"

# Encryption Key (32 bytes, hex encoded)
export REIGNX_ENCRYPTION_KEY="your_64_character_hex_encoded_key_here"

# Admtools Container Passwords (only for development/testing!)
export ROOT_PASSWORD="your_secure_root_password"
export USER_PASSWORD="your_secure_user_password"

# Generate secure passwords:
# openssl rand -base64 32
# openssl rand -hex 32
